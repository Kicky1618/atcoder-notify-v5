# Host ports
APP_PORT=4080
SCRAPING_PORT=4082
DB_PORT=3306
REDIS_PORT=6379

# Database used by Prisma in compose services
MARIADB_DATABASE=defaultdb
MARIADB_ROOT_PASSWORD=password
DATABASE_URL=mysql://root:password@db:3306/defaultdb

# Web/session settings
DOMAIN=
SESSION_SECRET_KEY=change-me
TURNSTILE_SITEKEY=
TURNSTILE_SECRET=

# Scraping/SSE proxy settings
PROXY_HOST=scraping
PROXY_PORT=4082
SOCK5_PROXY=

# Optional Discord bot token for npm run start:discord outside compose
TOKEN=
